.programmes .section-kicker,
.method .section-kicker,
.results .section-kicker,
.contact .section-kicker {
  color: var(--red);
}

.intro-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1px;
  border: 1px solid var(--line);
  background: var(--line);
}

.intro-grid article {
  min-height: 250px;
  padding: 28px;
  background: var(--ivory);
}

.intro-grid span {
  color: var(--amber);
  font-family: Inter, ui-sans-serif, system-ui, sans-serif;
  font-size: 12px;
  font-weight: 900;
}

h3 {
  margin: 22px 0 12px;
  font-size: 26px;
}

p {
  font-family: Inter, ui-sans-serif, system-ui, sans-serif;
  line-height: 1.65;
}

.intro-grid p,
.programme p,
.method-panel p,
.contact-copy p,
.footer span:last-child {
  color: var(--ink-soft);
}

.programmes {
  background: var(--paper);
}

.section-heading {
  display: grid;
  grid-template-columns: 0.38fr 1fr;
  gap: 30px;
  align-items: start;
  margin-bottom: 34px;
}

.programme-list {
  display: grid;
  gap: 14px;
}

.programme {
  display: grid;
  grid-template-columns: minmax(210px, 0.65fr) 1fr auto;
  align-items: center;
  gap: 26px;
  padding: 26px 30px;
  border: 1px solid var(--line);
  background: rgba(255, 250, 240, 0.7);
}

.programme h3 {
  margin: 0;
}

.programme-type {
  margin-bottom: 6px;
  color: var(--red);
}

.programme a {
  border-bottom: 2px solid var(--amber);
  font-family: Inter, ui-sans-serif, system-ui, sans-serif;
  font-weight: 850;
}

.method {
  display: grid;
  grid-template-columns: minmax(280px, 0.85fr) 1.15fr;
  gap: 24px;
  background: var(--moss-dark);
  color: var(--ivory);
}

.method-panel {
  padding-right: clamp(0px, 5vw, 72px);
}

.method-panel p {
  max-width: 580px;
  color: rgba(255, 250, 240, 0.72);
}

.steps {
  display: grid;
  gap: 14px;
  align-content: center;
}

.steps div {
  display: grid;
  grid-template-columns: 130px 1fr;
  gap: 20px;
  padding: 24px;
  border-left: 4px solid var(--amber-light);
  background: rgba(255, 250, 240, 0.08);
}

.steps strong {
  font-size: 25px;
}

.steps span {
  color: rgba(255, 250, 240, 0.75);
  font-family: Inter, ui-sans-serif, system-ui, sans-serif;
  line-height: 1.6;
}

.results {
  display: grid;
  grid-template-columns: 0.9fr 1.1fr;
  gap: 38px;
  background: var(--ivory);
}

.metrics {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
  align-items: stretch;
}

.metrics div {
  display: grid;
  align-content: center;
  min-height: 180px;
  padding: 24px;
  border: 1px solid var(--line);
}

.metrics strong {
  color: var(--red);
  font-size: clamp(42px, 6vw, 76px);
  line-height: 1;
}

.metrics span {
  margin-top: 10px;
  color: var(--ink-soft);
  font-family: Inter, ui-sans-serif, system-ui, sans-serif;
  line-height: 1.45;
}

.contact {
  display: grid;
  grid-template-columns: minmax(280px, 0.85fr) minmax(300px, 520px);
  gap: clamp(30px, 8vw, 110px);
  background: var(--paper);
}

.contact-form {
  display: grid;
  gap: 16px;
  padding: 28px;
  border: 1px solid var(--line);
  background: var(--ivory);
  box-shadow: var(--shadow);
}

.contact-form label {
  display: grid;
  gap: 8px;
  color: var(--ink-soft);
  font-family: Inter, ui-sans-serif, system-ui, sans-serif;
  font-size: 13px;
  font-weight: 800;
  text-transform: uppercase;
}

input,
select,
textarea {
  width: 100%;
  border: 1px solid rgba(22, 32, 29, 0.24);
  border-radius: 2px;
  padding: 13px 14px;
  background: #fffdf8;
  color: var(--ink);
  font: 16px Inter, ui-sans-serif, system-ui, sans-serif;
}

textarea {
  resize: vertical;
}

.contact-form button {
  width: 100%;
  border: 0;
}

.footer {
  display: flex;
  justify-content: space-between;
  gap: 20px;
  padding: 28px clamp(18px, 5vw, 72px);
  background: var(--ink);
  color: var(--ivory);
  font-family: Inter, ui-sans-serif, system-ui, sans-serif;
  font-size: 14px;
}

@media (max-width: 960px) {
  .site-header {
    grid-template-columns: 1fr auto;
    gap: 14px;
  }

  .nav {
    display: none;
  }

  .hero-content {
    margin-right: 24px;
  }

  .intro,
  .section-heading,
  .method,
  .results,
  .contact {
    grid-template-columns: 1fr;
  }

  .intro-grid,
  .metrics {
    grid-template-columns: 1fr;
  }

  .programme {
    grid-template-columns: 1fr;
    gap: 12px;
  }
}

@media (max-width: 640px) {
  .site-header {
    position: absolute;
    grid-template-columns: 1fr;
    padding: 14px 16px;
  }

  .header-controls {
    justify-self: stretch;
    justify-content: space-between;
  }

  .brand span:last-child {
    max-width: none;
    white-space: normal;
    line-height: 1.08;
  }

  .header-action {
    padding: 10px 14px;
    font-size: 12px;
  }

  .hero {
    min-height: 88vh;
    align-items: end;
  }

  .hero-shade {
    background:
      linear-gradient(0deg, rgba(8, 13, 12, 0.88), rgba(8, 13, 12, 0.58) 58%, rgba(8, 13, 12, 0.18)),
      linear-gradient(90deg, rgba(8, 13, 12, 0.12), rgba(8, 13, 12, 0.32));
  }

  .hero-content {
    width: calc(100% - 32px);
    margin: 0 16px 40px;
    padding-top: 120px;
  }

  .hero h1 {
    font-size: clamp(48px, 15vw, 72px);
  }

  .button {
    width: 100%;
  }

  .steps div {
    grid-template-columns: 1fr;
  }

  .footer {
    flex-direction: column;
  }
}
